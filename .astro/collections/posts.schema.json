{
  "$ref": "#/definitions/posts",
  "definitions": {
    "posts": {
      "type": "object",
      "properties": {
        "title": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 120
                },
                "slug": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "name",
                "slug"
              ],
              "additionalProperties": false
            }
          ]
        },
        "advanced": {
          "type": "object",
          "properties": {
            "discriminant": {
              "type": "boolean"
            },
            "value": {
              "type": "object",
              "properties": {
                "excerpt": {
                  "type": "string",
                  "maxLength": 200
                },
                "cover": {
                  "type": "string"
                },
                "category": {
                  "type": "string"
                },
                "tags": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "maxItems": 8
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "draft",
                    "published"
                  ]
                },
                "seoTitle": {
                  "type": "string"
                },
                "seoDescription": {
                  "type": "string",
                  "maxLength": 160
                },
                "canonical": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "additionalProperties": false
            }
          },
          "required": [
            "discriminant"
          ],
          "additionalProperties": false
        },
        "publishedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updatedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}