---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPostAuthorName, getPostDates, getPublishedPostBySlug } from '../../lib/posts';
import { requireDb } from '../../lib/db';
import { marked } from 'marked';

export const prerender = false;

const db = requireDb(Astro.locals);
const slug = String(Astro.params.slug || '');
const post = await getPublishedPostBySlug(db, slug);
if (!post) {
  Astro.response.status = 404;
}
const title = post ? (typeof post.data.title === 'string' ? post.data.title : post.data.title.name) : '文章不存在';
const pageTitle =
  (post?.data.advanced?.discriminant ? post.data.advanced.value?.seoTitle : undefined) || title;
const pageDescription =
  (post?.data.advanced?.discriminant ? post.data.advanced.value?.seoDescription : undefined) || title;
const canonical = post?.data.advanced?.discriminant ? post.data.advanced.value?.canonical : undefined;
const { publishedAt, updatedAt } = await getPostDates(
  post || {
    data: {
      publishedAt: new Date(),
      updatedAt: new Date(),
    },
  }
);
const publishedDate = publishedAt.toLocaleString('zh-CN', { hour12: false });
const updatedDate = updatedAt.toLocaleString('zh-CN', { hour12: false });
const authorName = post ? await getPostAuthorName(db, post) : '系统';
const tags = post?.data.advanced?.discriminant ? post.data.advanced.value?.tags || [] : [];
const html = post ? await marked.parse(post.body) : '';
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical}>
  <article class="article">
    {!post && <p class="post-meta">文章不存在或未发布。</p>}
    {post && (
      <>
    <header class="article-header">
      <h1>{title}</h1>
      <p class="post-meta">
        {authorName} · 发布于 {publishedDate} · 更新于 {updatedDate}
      </p>
      <div class="chips">
        {tags.map((tag: string) => (
          <a class="chip" href={`/tags/${encodeURIComponent(tag)}`}>#{tag}</a>
        ))}
      </div>
    </header>
    <hr />
    <div class="post-content">
      <div set:html={html}></div>
    </div>
      </>
    )}
  </article>
</BaseLayout>
