---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPostDates, getPostSlug, getPublishedPosts } from '../../lib/posts';
import { render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const title = typeof post.data.title === 'string' ? post.data.title : post.data.title.name;
const pageTitle =
  (post.data.advanced?.discriminant ? post.data.advanced.value?.seoTitle : undefined) || title;
const pageDescription =
  (post.data.advanced?.discriminant ? post.data.advanced.value?.seoDescription : undefined) || title;
const canonical = post.data.advanced?.discriminant ? post.data.advanced.value?.canonical : undefined;
const { publishedAt, updatedAt } = await getPostDates(post);
const publishedDate = publishedAt.toLocaleString('zh-CN', { hour12: false });
const updatedDate = updatedAt.toLocaleString('zh-CN', { hour12: false });
const category = post.data.advanced?.discriminant ? post.data.advanced.value?.category || '未分类' : '未分类';
const tags = post.data.advanced?.discriminant ? post.data.advanced.value?.tags || [] : [];
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical}>
  <article class="article">
    <header class="article-header">
      <h1>{title}</h1>
      <p class="post-meta">
        {category} · 发布于 {publishedDate} · 更新于 {updatedDate}
      </p>
      <div class="chips">
        {tags.map((tag: string) => (
          <a class="chip" href={`/tags/${encodeURIComponent(tag)}`}>#{tag}</a>
        ))}
      </div>
    </header>
    <hr />
    <Content />
  </article>
</BaseLayout>
