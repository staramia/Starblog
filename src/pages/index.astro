---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPostAuthorName, getPostDates, getPostSlug, getPublishedPosts } from '../lib/posts';
import { requireDb } from '../lib/db';

const db = requireDb(Astro.locals);
const posts = await getPublishedPosts(db);
const latest = posts.slice(0, 6);
const totalPosts = posts.length;
const authors = new Set(await Promise.all(posts.map((post) => getPostAuthorName(db, post)))).size;
const tags = new Set(
  posts.flatMap((post) => (post.data.advanced?.discriminant ? post.data.advanced.value?.tags || [] : []))
).size;

function displayDate(post: { data: { publishedAt?: Date } }) {
  return (post.data.publishedAt || new Date()).toLocaleString('zh-CN', { hour12: false });
}

const publishedDateMap = new Map<string, string>();
const authorMap = new Map<string, string>();
for (const post of latest) {
  const slug = getPostSlug(post);
  const { publishedAt } = await getPostDates(post);
  publishedDateMap.set(slug, publishedAt.toLocaleString('zh-CN', { hour12: false }));
  authorMap.set(slug, await getPostAuthorName(db, post));
}

function titleOf(post: { data: { title: string | { name: string } } }) {
  return typeof post.data.title === 'string' ? post.data.title : post.data.title.name;
}

function tagsOf(post: { data: { advanced?: { discriminant?: boolean; value?: { tags?: string[] } } } }) {
  return post.data.advanced?.discriminant ? post.data.advanced.value?.tags || [] : [];
}

function excerptOf(post: {
  body?: string;
  data: { advanced?: { discriminant?: boolean; value?: { excerpt?: string } } };
}) {
  const manual = post.data.advanced?.discriminant ? post.data.advanced.value?.excerpt || '' : '';
  if (manual.trim()) return manual.trim();

  const source = String(post.body || '');
  const plain = source
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/!\[[^\]]*\]\([^)]*\)/g, ' ')
    .replace(/\[[^\]]*\]\([^)]*\)/g, '$1')
    .replace(/^#{1,6}\s+/gm, '')
    .replace(/^>\s?/gm, '')
    .replace(/[*_~>-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

  return plain.slice(0, 110);
}
---

<BaseLayout title="Starblog | 首页" description="一个支持可视化编辑与自动部署的 Astro 个人博客。">
  <section class="hero">
    <h1>星梦祈雪的博客平台</h1>
    <p>
      关注星梦祈雪喵，关注星梦祈雪谢谢喵。
    </p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="/admin/posts">开始写作</a>
      <a class="btn btn-secondary" href="/nav">浏览导航</a>
    </div>
    <div class="stats-grid">
      <div class="stat">
        <p class="stat-value">{totalPosts}</p>
        <p class="stat-label">已发布文章</p>
      </div>
      <div class="stat">
        <p class="stat-value">{authors}</p>
        <p class="stat-label">作者数量</p>
      </div>
      <div class="stat">
        <p class="stat-value">{tags}</p>
        <p class="stat-label">标签数量</p>
      </div>
    </div>
  </section>

  <section>
    <div class="section-title">
      <h2>最新文章</h2>
    </div>
    <div class="post-grid">
      {latest.map((post) => (
        <article class="post-card">
          <h2><a href={`/posts/${getPostSlug(post)}`}>{titleOf(post)}</a></h2>
          <p class="post-meta">
            {authorMap.get(getPostSlug(post)) || '系统'} · {publishedDateMap.get(getPostSlug(post)) || displayDate(post)}
          </p>
          {excerptOf(post) && <p class="post-excerpt">{excerptOf(post)}</p>}
          <div class="chips">
            {tagsOf(post).map((tag) => (
              <a class="chip" href={`/tags/${encodeURIComponent(tag)}`}>#{tag}</a>
            ))}
          </div>
        </article>
      ))}
    </div>
    {latest.length === 0 && (
      <div class="empty-state">
        <p>还没有发布的文章，先去后台写第一篇吧。</p>
        <a class="btn btn-primary" href="/admin/posts">前往创作者后台</a>
      </div>
    )}
  </section>
</BaseLayout>
