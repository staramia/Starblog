---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPostDates, getPostSlug, getPublishedPosts, groupByCategory } from '../../lib/posts';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const grouped = groupByCategory(posts);
  return Object.entries(grouped).map(([category, entries]) => ({
    params: { category },
    props: { category, entries },
  }));
}

const { category, entries } = Astro.props;

function displayDate(post: { data: { publishedAt?: Date } }) {
  return (post.data.publishedAt || new Date()).toLocaleString('zh-CN', { hour12: false });
}

const publishedDateMap = new Map<string, string>();
for (const post of entries) {
  const { publishedAt } = await getPostDates(post);
  publishedDateMap.set(getPostSlug(post), publishedAt.toLocaleString('zh-CN', { hour12: false }));
}

function titleOf(post: { data: { title: string | { name: string } } }) {
  return typeof post.data.title === 'string' ? post.data.title : post.data.title.name;
}
---

<BaseLayout title={`${category} | 分类`} description={`分类 ${category} 下的文章列表`}>
  <section class="article">
    <h1>分类：{category}</h1>
    <ul class="list-board">
      {entries.map((post: any) => (
        <li class="list-item">
          <a href={`/posts/${getPostSlug(post)}`}>{titleOf(post)}</a>
          <span class="post-meta">{publishedDateMap.get(getPostSlug(post)) || displayDate(post)}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
